<!DOCTYPE html>
<html lang="ne">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Shoe Zone - Best Shoes Store</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <div class="logo">Shoe<span>Zone</span></div>
        <nav>
            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">Men</a></li>
                <li><a href="#">Women</a></li>
                <li><a href="#">Contact</a></li>
            </ul>
        </nav>
    </header>

    <section class="hero">
        <div class="hero-content">
            <h2>Step Up Your Style</h2>
            <p>Find the perfect pair for your everyday hustle. Comfort and style combined.</p>
            <a href="#" class="btn">Shop Now</a>
        </div>
    </section>

    <main>
        <h2 class="section-title">Our Best Sellers</h2>
        <div class="product-grid">
            
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400" alt="Sneaker Red">
                <h3>Sporty Red Sneakers</h3>
                <p class="price">Rs. 4,500</p>
                <button class="add-to-cart">Add to Cart</button>
            </div>

            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=400" alt="Sneaker Colorful">
                <h3>Casual Air Sneakers</h3>
                <p class="price">Rs. 5,200</p>
                <button class="add-to-cart">Add to Cart</button>
            </div>

            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=400" alt="Nike Lime">
                <h3>Neon Sport Shoes</h3>
                <p class="price">Rs. 6,000</p>
                <button class="add-to-cart">Add to Cart</button>
            </div>

        </div>
    </main>

    <footer>
        <p>&copy; 2026 ShoeZone. All Rights Reserved.</p>
    </footer>

</body>
</html>
